{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ix-autonomy-assurance-case-runtime/scenario-catalog.schema.json",
  "title": "IX Autonomy Scenario Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operational_contexts",
    "autonomy_functions",
    "operating_conditions",
    "stressors",
    "expected_behaviors",
    "acceptance_criteria",
    "mission_threads",
    "scenarios"
  ],
  "properties": {
    "operational_contexts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operational_context"
      }
    },
    "autonomy_functions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/autonomy_function"
      }
    },
    "operating_conditions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operating_condition"
      }
    },
    "stressors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stressor"
      }
    },
    "expected_behaviors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/expected_behavior"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/acceptance_criterion"
      }
    },
    "mission_threads": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mission_thread"
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scenario"
      }
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "hazard_severity": {
      "type": "string",
      "enum": [
        "negligible",
        "minor",
        "major",
        "critical",
        "catastrophic"
      ]
    },
    "autonomy_decision": {
      "type": "string",
      "enum": [
        "allow",
        "clamp",
        "defer",
        "veto",
        "safe_hold"
      ]
    },
    "authority_state": {
      "type": "string",
      "enum": [
        "autonomous_allowed",
        "human_approval_required",
        "human_override_active",
        "denied",
        "emergency_safe_hold"
      ]
    },
    "verification_result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "inconclusive",
        "not_run"
      ]
    },
    "operational_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_id",
        "name",
        "environment",
        "mission_phase",
        "description"
      ],
      "properties": {
        "context_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "mission_phase": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "autonomy_function": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "function_id",
        "name",
        "description",
        "input_signals",
        "output_actions"
      ],
      "properties": {
        "function_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "input_signals": {
          "$ref": "#/$defs/string_array"
        },
        "output_actions": {
          "$ref": "#/$defs/string_array"
        },
        "nominal_authority_state": {
          "$ref": "#/$defs/authority_state"
        }
      }
    },
    "operating_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition_id",
        "name",
        "description",
        "telemetry_key",
        "expected_range"
      ],
      "properties": {
        "condition_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "telemetry_key": {
          "type": "string",
          "minLength": 1
        },
        "expected_range": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stressor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stressor_id",
        "name",
        "description",
        "severity",
        "affected_capabilities",
        "trigger_condition"
      ],
      "properties": {
        "stressor_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/hazard_severity"
        },
        "affected_capabilities": {
          "$ref": "#/$defs/string_array"
        },
        "trigger_condition": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "behavior_id",
        "description",
        "required_decision",
        "required_authority_state",
        "rationale"
      ],
      "properties": {
        "behavior_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required_decision": {
          "$ref": "#/$defs/autonomy_decision"
        },
        "required_authority_state": {
          "$ref": "#/$defs/authority_state"
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "acceptance_criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterion_id",
        "statement",
        "measurement",
        "expected_result"
      ],
      "properties": {
        "criterion_id": {
          "type": "string",
          "minLength": 1
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "measurement": {
          "type": "string",
          "minLength": 1
        },
        "expected_result": {
          "type": "string",
          "minLength": 1
        },
        "required_verification_result": {
          "$ref": "#/$defs/verification_result"
        },
        "requires_evidence": {
          "type": "boolean"
        }
      }
    },
    "mission_thread": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission_thread_id",
        "name",
        "objective",
        "operational_context_id",
        "autonomy_function_ids"
      ],
      "properties": {
        "mission_thread_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "operational_context_id": {
          "type": "string",
          "minLength": 1
        },
        "autonomy_function_ids": {
          "$ref": "#/$defs/string_array"
        },
        "scenario_ids": {
          "$ref": "#/$defs/string_array"
        },
        "requirement_ids": {
          "$ref": "#/$defs/string_array"
        },
        "hazard_ids": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "mission_thread_id",
        "title",
        "description",
        "operational_context_id",
        "autonomy_function_id",
        "operating_condition_ids",
        "stressor_ids",
        "expected_behavior_id",
        "acceptance_criterion_ids"
      ],
      "properties": {
        "scenario_id": {
          "type": "string",
          "minLength": 1
        },
        "mission_thread_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "operational_context_id": {
          "type": "string",
          "minLength": 1
        },
        "autonomy_function_id": {
          "type": "string",
          "minLength": 1
        },
        "operating_condition_ids": {
          "$ref": "#/$defs/string_array"
        },
        "stressor_ids": {
          "$ref": "#/$defs/string_array"
        },
        "expected_behavior_id": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_criterion_ids": {
          "$ref": "#/$defs/string_array"
        },
        "hazard_ids": {
          "$ref": "#/$defs/string_array"
        },
        "evidence_ids": {
          "$ref": "#/$defs/string_array"
        }
      }
    }
  }
}
